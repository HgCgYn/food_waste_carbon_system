# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=food_waste_carbon
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql+psycopg2://postgres:change-me@postgres:5432/food_waste_carbon

# ── VLM (Vision Language Model) API Keys ─────────────────────────────────────
# 使用 YOLO + Gemini 或 YOLO + GPT 模式時需要填入對應的 API Key。

# Google Gemini
# 申請網址：https://aistudio.google.com/app/apikey
# 費用說明：Gemini 2.5 Flash 約 $0.075 USD / 1M tokens（每張圖片 < NT$0.05）
# 最低儲值：NT$400（建議用台幣信用卡儲值）
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI GPT-4o
# 申請網址：https://platform.openai.com/api-keys
# 費用說明：GPT-4o 約 $0.01 USD / 張（detail=low 模式），測試 100 張 ≈ $1 USD
# 最低儲值：$5 USD（約台幣 160 元）
OPENAI_API_KEY=your-openai-api-key-here
